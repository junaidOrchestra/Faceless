# --- Brollio frontend config ----------------------------------------------

# Set to 1 to route the editor through the real orchestrator (via the built-in
# Next.js proxy routes). Leave unset / 0 to run on mock data with no backend.
NEXT_PUBLIC_USE_ORCHESTRATOR=0

# Orchestrator (FastAPI) base URL the server-side proxy talks to. Inside the
# bundled docker-compose network this is the service name; locally it's the
# host port. The user's Supabase access token is attached server-side as the
# Bearer header — never sent to the browser.
ORCHESTRATOR_URL=http://localhost:8000

# --- Supabase Auth (authentication only) --------------------------------
# Create a project and enable Email + Google — see SETUP.md at repo root.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server only — never prefix with NEXT_PUBLIC_ or expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Orchestrator serves GET /videos/{id}/audio so the synced preview can pull
# narration after a reload (optional).
NEXT_PUBLIC_AUDIO_PROXY=1
