LOG_LEVEL=
CLIP_MODEL_NAME=
CLIP_DEVICE=
ENABLED_SOURCES=
ENABLE_CACHE_FIRST=
ITEM_CONCURRENCY=
WORKER_POLL_INTERVAL_S=
JOB_RUNNING_TIMEOUT_S=
JOB_TTL_S=
MAX_ITEMS_PER_JOB=
# Required by Wikimedia: AppName/Version (contact URL; email) with REAL contact.
HTTP_USER_AGENT="FacelessFlow/1.0 (https://yoursite.example; you@example.com)"
