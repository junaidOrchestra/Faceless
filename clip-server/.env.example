DATABASE_URL=
# IPv4 pinning is ON by default (needed on IPv6-less hosts like Hugging Face
# Spaces talking to dual-stack Neon). Uncomment and set to false only if you
# must use IPv6. Leave it OUT entirely to keep the default (do not set empty).
# DB_FORCE_IPV4=false
API_AUTH_SECRET=
LOG_LEVEL=
# Shared cloud Redis (set the SAME value as the orchestrator's REDIS_URL). The
# clip-server publishes finished job results here for the orchestrator to consume.
REDIS_URL=
# Optional: base name of the result queue. Must match the orchestrator's
# CLIP_RESULT_QUEUE. Default "clip_result" works if left unset on both sides.
# CLIP_RESULT_QUEUE=clip_result
# Source API keys — read from THIS environment (no longer sent by the orchestrator).
PEXELS_API_KEY=
PIXABAY_API_KEY=
FLICKR_API_KEY=
CLIP_MODEL_NAME=
CLIP_DEVICE=
ENABLED_SOURCES=
ENABLE_CACHE_FIRST=
ITEM_CONCURRENCY=
WORKER_POLL_INTERVAL_S=
JOB_RUNNING_TIMEOUT_S=
JOB_TTL_S=
MAX_ITEMS_PER_JOB=
# Required by Wikimedia: AppName/Version (contact URL; email) with REAL contact.
HTTP_USER_AGENT="FacelessFlow/1.0 (https://yoursite.example; you@example.com)"
