# IPv4 pinning is ON by default (needed on IPv6-less hosts like Hugging Face
# Spaces talking to dual-stack Neon). Uncomment and set to false only if you
# must use IPv6. Leave it OUT entirely to keep the default (do not set empty).
# DB_FORCE_IPV4=false
