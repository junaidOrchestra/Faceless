# Copy to .env and adjust as needed. All values have sane defaults baked into
# the backend, so the suite also runs with an empty/missing .env.

# --- Orchestrator connection ------------------------------------------------
# Default: the deployed HF Space (same as seemless/.env.local).
# For a LOCAL orchestrator started from the repo root docker-compose, use:
#   ORCHESTRATOR_URL=http://host.docker.internal:8000
#   ORCHESTRATOR_TOKEN=dev-orch-secret
ORCHESTRATOR_URL=https://junaidorchestra-orchestrator.hf.space
ORCHESTRATOR_TOKEN=orchestra-token-784631

# --- Clip search inputs forwarded to the orchestrator -----------------------
SOURCES=["pexels_video"]
PEXELS_KEY=y6T3FEbrm49ZEVp5XqkQINXcHQjvVkAs4iEKBdOgx3OfZvNS7rlOOBNu
# PIXABAY_KEY=

# --- Audio fetch ------------------------------------------------------------
AUDIO_BITRATE_KBPS=64
# PO-token provider (bgutil) sidecar URL. Lets yt-dlp fetch YouTube's gated
# (non-HLS) formats without manual cookies. Empty disables it.
POT_PROVIDER_URL=http://pot-provider:4416
# yt-dlp player clients (comma-separated). Empty = yt-dlp defaults (recommended
# with the PO-token provider).
YOUTUBE_PLAYER_CLIENTS=
# Format selector. Skips HLS (m3u8) audio, whose fragment downloader can return
# empty files ("The downloaded file is empty").
# YOUTUBE_AUDIO_FORMAT=bestaudio[protocol^=http]/bestaudio/best[protocol^=http][acodec!=none]/best
# Most reliable fix for "Sign in to confirm you're not a bot" / HTTP 429: drop a
# cookies.txt (exported from a logged-in browser) into the ./cookies folder — it
# is auto-detected, no setting needed. To force a specific file instead, set:
# YOUTUBE_COOKIES_FILE=/app/cookies/cookies.txt
# Transient 429s are also retried with backoff:
# YOUTUBE_FETCH_RETRIES=3
# YOUTUBE_RETRY_BACKOFF_S=20

# --- Pipeline behaviour -----------------------------------------------------
MAX_CONCURRENCY=2
POLL_INTERVAL_S=3
STAGE_TIMEOUT_S=2400
