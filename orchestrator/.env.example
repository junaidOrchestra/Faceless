DATABASE_URL=
# Legacy static bearer (unused for user routes after Supabase auth). Optional.
API_AUTH_SECRET=
LOG_LEVEL=

# --- Supabase Auth (verify user JWTs; see SETUP.md at repo root) ---------
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_JWT_SECRET=your-jwt-secret-from-supabase-dashboard
# SUPABASE_JWKS_URL=            # optional override for asymmetric signing
# SUPABASE_JWT_AUDIENCE=authenticated

# Rate limits (Redis). Set RATE_LIMIT_ENABLED=false to disable in dev/tests.
# RATE_LIMIT_CREATE_PER_MIN=10
# RATE_LIMIT_RENDER_PER_MIN=20

CLIP_SERVER_URL=
CLIP_SERVER_SECRET=
LLM_PROVIDER=
GEMINI_API_KEY=
GEMINI_MODEL=
CEREBRAS_API_KEY=
CEREBRAS_MODEL=
CEREBRAS_BASE_URL=
LLM_MAX_TOKENS=
LLM_REASONING_EFFORT=
LLM_REQUEST_TIMEOUT_S=
LLM_MAX_RETRIES=
LLM_RETRY_BACKOFF_S=
LLM_RETRY_BACKOFF_MAX_S=
LLM_CHUNK_SIZE=
LOCAL_LLM_MODEL_PATH=
ALLOWED_ORIGINS=
REDIS_URL=
# Shared cloud Redis is also used to receive finished clip-search results from
# the clip-server. CLIP_RESULT_QUEUE must match the clip-server's value; the
# default "clip_result" works if left unset on both sides.
# CLIP_RESULT_QUEUE=clip_result
# Per-stage worker pool sizes (staged pipeline: transcribe -> llm -> render).
TRANSCRIBE_CONCURRENCY=
LLM_CONCURRENCY=
RENDER_CONCURRENCY=
WORKER_POLL_INTERVAL_S=
# Idle Redis queue read timeout. Keep this well above 1s on managed/free Redis:
# lower values make idle workers issue many BLMOVE commands per hour.
WORKER_QUEUE_BLOCK_TIMEOUT_S=60
JOB_RUNNING_TIMEOUT_S=
CLIP_POLL_INTERVAL_S=
CLIP_POLL_TIMEOUT_S=
# Single clip poller: scan cadence and the max age before an awaiting_clip job fails.
CLIP_POLL_SCAN_INTERVAL_S=
CLIP_POLL_MAX_AGE_S=
MAX_UPLOAD_BYTES=
MAX_UPLOAD_DURATION_S=
RENDER_TEMP_DIR=
RESULT_BASE_URL=
# Result storage: leave STORAGE_LOCAL=true to keep files on disk, or set it to
# false to upload media to an S3-compatible bucket via the S3 API. When false,
# the B2_* vars below are required. Backblaze B2 S3 endpoint + region, e.g.:
#   B2_S3_ENDPOINT=https://s3.us-west-004.backblazeb2.com
#   B2_S3_REGION=us-west-004
STORAGE_LOCAL=
B2_S3_ENDPOINT=
B2_S3_REGION=
B2_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET_NAME=
B2_PREFIX=
# Optional: public bucket / custom domain base URL. If unset, private buckets
# are served via short-lived presigned URLs.
B2_PUBLIC_BASE_URL=
DEFAULT_SOURCES=
MAX_FALLBACK_RATIO=
WHISPER_MODEL_SIZE=
BEAT_MIN_DURATION_S=
BEAT_TARGET_DURATION_S=
BEAT_MAX_DURATION_S=
BEAT_PAUSE_THRESHOLD_S=
